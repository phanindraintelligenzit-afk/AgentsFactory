# Environment variables for AI SOC2 Compliance Agent

# App
DEBUG=true
DATABASE_URL=sqlite:///./soc2_agent.db

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# Worker
EVIDENCE_SCAN_INTERVAL_HOURS=24
MAX_EVIDENCE_PER_CONTROL=50

# LLM (for evidence analysis / policy generation)
LLM_PROVIDER=openrouter
LLM_MODEL=openrouter/owl-alpha
LLM_API_KEY=

# Notifications (optional)
SLACK_WEBHOOK_URL=

# Evidence storage (optional)
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
