# Environment variables for AI Competitive Intelligence Agent

# App
DEBUG=true

# Database
DATABASE_URL=sqlite:///./ci_agent.db

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# Worker
SCAN_INTERVAL_MINUTES=60
MAX_COMPETITORS=50

# LLM (for battlecard generation)
LLM_PROVIDER=openrouter
LLM_MODEL=openrouter/owl-alpha
LLM_API_KEY=

# Notifications (optional)
SLACK_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
