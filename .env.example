# Environment Configuration
# Copy to .env and fill in your values

# LLM Provider (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_DEFAULT_MODEL=openrouter/owl-alpha

# App Settings
AGENTSFACTORY_ENV=development
AGENTSFACTORY_LOG_LEVEL=INFO
AGENTSFACTORY_DATABASE_URL=sqlite+aiosqlite:///./agentsfactory.db

# Optional: AWS Bedrock (alternative provider)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Optional: Postgres (alternative to SQLite)
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/agentsfactory
